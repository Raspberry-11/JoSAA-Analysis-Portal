# JOSAA Portal — Environment Config
# Copy this file to .env and update values for your environment.

# ─── Database (XAMPP defaults) ───────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=josaa_portal
DB_USER=root
DB_PASS=

# ─── Groq API (for the AI Analyst) ───────
# Get a free API key at: https://console.groq.com/keys
GROQ_API_KEY="PUT YOURK KEY HERE"

# Optional: override the default model
# Recommended: llama-3.3-70b-versatile (best for SQL generation)
# Alternative: llama-3.1-70b-versatile, qwen-2.5-32b
# GROQ_MODEL=llama-4-scout-17b-16e-instruct
